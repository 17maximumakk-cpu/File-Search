<?php
// search.php - Поиск файлов на PHP (CLI + веб)
// Использование CLI: php search.php /путь "*.txt"
// Веб-версия: открыть в браузере и указать параметры

if (php_sapi_name() === 'cli') {
    // CLI режим
    if ($argc < 2) {
        echo "Использование: php search.php <папка> [маска] [--content=текст] [--ext=txt,php]\n";
        exit(1);
    }
    $path = $argv[1];
    $pattern = $argv[2] ?? '*';
    $searchContent = null;
    $extensions = [];
    for ($i = 3; $i < $argc; $i++) {
        if (strpos($argv[$i], '--content=') === 0) $searchContent = substr($argv[$i], 10);
        if (strpos($argv[$i], '--ext=') === 0) $extensions = explode(',', substr($argv[$i], 6));
    }
    searchFilesCLI($path, $pattern, $extensions, $searchContent);
} else {
    // Веб-режим
    ?>
    <!DOCTYPE html>
    <html>
    <head>
        <meta charset="UTF-8">
        <title>🔍 Поиск файлов на PHP</title>
        <style>
            body { font-family: monospace; margin: 20px; background: #f5f5f5; }
            .container { max-width: 1000px; margin: 0 auto; background: white; padding: 20px; border-radius: 12px; }
            input, button { padding: 8px; margin: 5px; }
            table { width: 100%; border-collapse: collapse; margin-top: 20px; }
            th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
            th { background: #2c3e50; color: white; }
            tr:hover { background: #f1f1f1; cursor: pointer; }
        </style>
    </head>
    <body>
    <div class="container">
        <h2>🔍 Поиск файлов (PHP)</h2>
        <form method="POST">
            <label>Папка: <input type="text" name="path" value="<?= htmlspecialchars($_POST['path'] ?? getcwd()) ?>" size="50"></label><br>
            <label>Маска имени: <input type="text" name="pattern" value="<?= htmlspecialchars($_POST['pattern'] ?? '*') ?>"></label><br>
            <label>Расширения (через запятую): <input type="text" name="extensions" value="<?= htmlspecialchars($_POST['extensions'] ?? '') ?>"></label><br>
            <label>Содержит текст: <input type="text" name="content" value="<?= htmlspecialchars($_POST['content'] ?? '') ?>"></label><br>
            <button type="submit">🔍 Найти</button>
        </form>
        <?php
        if ($_SERVER['REQUEST_METHOD'] === 'POST') {
            $path = $_POST['path'] ?? '.';
            $pattern = $_POST['pattern'] ?? '*';
            $extensions = array_filter(array_map('trim', explode(',', $_POST['extensions'] ?? '')));
            $searchContent = $_POST['content'] ?? '';
            searchFilesWeb($path, $pattern, $extensions, $searchContent);
        }
        ?>
    </div>
    <script>
        document.querySelectorAll('table tr').forEach(row => {
            row.addEventListener('click', () => {
                const path = row.cells[1]?.innerText;
                if (path) alert('Открыть файл? ' + path);
            });
        });
    </script>
    </body>
    </html>
    <?php
}

function searchFilesCLI($path, $pattern, $extensions, $searchContent) {
    $regex = '/^' . str_replace(['*', '?'], ['.*', '.'], preg_quote($pattern, '/')) . '$/i';
    $iterator = new RecursiveIteratorIterator(new RecursiveDirectoryIterator($path, RecursiveDirectoryIterator::SKIP_DOTS));
    $count = 0;
    foreach ($iterator as $file) {
        if ($file->isDir()) continue;
        $name = $file->getFilename();
        if (!preg_match($regex, $name)) continue;
        $ext = strtolower($file->getExtension());
        if (!empty($extensions) && !in_array($ext, $extensions)) continue;
        if (!empty($searchContent)) {
            $content = file_get_contents($file->getRealPath());
            if (stripos($content, $searchContent) === false) continue;
        }
        echo $file->getRealPath() . " (" . $file->getSize() . " bytes)\n";
        $count++;
    }
    echo "\n✅ Найдено файлов: $count\n";
}

function searchFilesWeb($path, $pattern, $extensions, $searchContent) {
    $regex = '/^' . str_replace(['*', '?'], ['.*', '.'], preg_quote($pattern, '/')) . '$/i';
    $results = [];
    $iterator = new RecursiveIteratorIterator(new RecursiveDirectoryIterator($path, RecursiveDirectoryIterator::SKIP_DOTS));
    foreach ($iterator as $file) {
        if ($file->isDir()) continue;
        $name = $file->getFilename();
        if (!preg_match($regex, $name)) continue;
        $ext = strtolower($file->getExtension());
        if (!empty($extensions) && !in_array($ext, $extensions)) continue;
        if (!empty($searchContent)) {
            $content = @file_get_contents($file->getRealPath());
            if ($content === false || stripos($content, $searchContent) === false) continue;
        }
        $results[] = [
            'name' => $name,
            'path' => $file->getRealPath(),
            'size' => $file->getSize(),
            'modified' => date('Y-m-d H:i:s', $file->getMTime())
        ];
    }
    if (empty($results)) {
        echo "<p>Ничего не найдено.</p>";
    } else {
        echo "<table><tr><th>Имя</th><th>Путь</th><th>Размер</th><th>Изменён</th></tr>";
        foreach ($results as $r) {
            echo "<tr><td>{$r['name']}</td><td>{$r['path']}</td><td>{$r['size']}</td><td>{$r['modified']}</td></tr>";
        }
        echo "</table><p>Найдено: " . count($results) . "</p>";
    }
}
?>
